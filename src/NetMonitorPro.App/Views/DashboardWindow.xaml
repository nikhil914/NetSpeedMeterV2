<Window x:Class="NetMonitorPro.App.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="NetMonitor Pro — Dashboard"
        Width="1100" Height="700"
        MinWidth="900" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Sidebar button style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="6,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C2333"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════ SIDEBAR ═══════════ -->
        <Border Grid.Column="0" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App title -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="NetMonitor" FontSize="20" FontWeight="Bold" Foreground="#00E676"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="PRO" FontSize="10" FontWeight="Bold" Foreground="#42A5F5"
                               Margin="0,-2,0,0"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel>
                    <Button Style="{StaticResource SidebarButton}" Content="📊  Overview"
                            Command="{Binding NavigateToCommand}" CommandParameter="Overview"/>
                    <Button Style="{StaticResource SidebarButton}" Content="📈  Usage History"
                            Command="{Binding NavigateToCommand}" CommandParameter="Usage"/>
                    <Button Style="{StaticResource SidebarButton}" Content="🌐  Network Info"
                            Command="{Binding NavigateToCommand}" CommandParameter="Network"/>
                    <Button Style="{StaticResource SidebarButton}" Content="⚡  Speed Test"
                            Command="{Binding NavigateToCommand}" CommandParameter="SpeedTest"/>
                    <Button Style="{StaticResource SidebarButton}" Content="⚙  Settings"
                            Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Header -->
                <TextBlock Text="{Binding CurrentPage}" FontSize="24" FontWeight="SemiBold"
                           Foreground="#E6EDF3" Margin="0,0,0,16" FontFamily="Segoe UI"/>

                <!-- ────── OVERVIEW PAGE ────── -->
                <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVisConverter}, ConverterParameter=Overview}"
                            x:Name="OverviewPanel">

                    <!-- Speed cards row -->
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                        <!-- Download speed card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="DOWNLOAD" FontSize="10" Foreground="#8B949E"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DownloadSpeed}" FontSize="22" FontWeight="Bold"
                                           Foreground="#00E676" Margin="0,4,0,0"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>

                        <!-- Upload speed card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="UPLOAD" FontSize="10" Foreground="#8B949E"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding UploadSpeed}" FontSize="22" FontWeight="Bold"
                                           Foreground="#42A5F5" Margin="0,4,0,0"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>

                        <!-- Session downloaded card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="SESSION ↓" FontSize="10" Foreground="#8B949E"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SessionDownloaded}" FontSize="22" FontWeight="Bold"
                                           Foreground="#BB86FC" Margin="0,4,0,0"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>

                        <!-- Session uploaded card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="SESSION ↑" FontSize="10" Foreground="#8B949E"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SessionUploaded}" FontSize="22" FontWeight="Bold"
                                           Foreground="#FF7043" Margin="0,4,0,0"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Real-time speed chart -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Real-Time Speed" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#E6EDF3" Margin="0,0,0,8"/>
                            <lvc:CartesianChart 
                                Series="{Binding SpeedSeries}"
                                XAxes="{Binding SpeedXAxes}"
                                YAxes="{Binding SpeedYAxes}"
                                Height="250"
                                AnimationsSpeed="00:00:00.100"
                                TooltipPosition="Top"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ────── USAGE HISTORY PAGE ────── -->
                <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVisConverter}, ConverterParameter=Usage}">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Last 30 Days" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#E6EDF3" Margin="0,0,0,8"/>
                            <lvc:CartesianChart
                                Series="{Binding DailyUsageSeries}"
                                XAxes="{Binding DailyXAxes}"
                                YAxes="{Binding DailyYAxes}"
                                Height="350"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ────── NETWORK INFO PAGE ────── -->
                <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVisConverter}, ConverterParameter=Network}">
                    <ItemsControl ItemsSource="{Binding Adapters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                                       Foreground="#E6EDF3"/>
                                            <Border Background="#21262D" CornerRadius="4" Padding="6,2" Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#8B949E"/>
                                            </Border>
                                            <Border Background="#0F3460" CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Type}" FontSize="11" Foreground="#42A5F5"/>
                                            </Border>
                                        </StackPanel>
                                        <UniformGrid Columns="2" Margin="0,4,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <TextBlock Text="IPv4: " Foreground="#8B949E" FontSize="12"/>
                                                <TextBlock Text="{Binding IPv4Address}" Foreground="#00E676" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <TextBlock Text="Gateway: " Foreground="#8B949E" FontSize="12"/>
                                                <TextBlock Text="{Binding DefaultGateway}" Foreground="#E6EDF3" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <TextBlock Text="Link Speed: " Foreground="#8B949E" FontSize="12"/>
                                                <TextBlock Text="{Binding FormattedSpeed}" Foreground="#E6EDF3" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <TextBlock Text="MAC: " Foreground="#8B949E" FontSize="12"/>
                                                <TextBlock Text="{Binding MacAddress}" Foreground="#E6EDF3" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <TextBlock Text="IPv6: " Foreground="#8B949E" FontSize="12"/>
                                                <TextBlock Text="{Binding IPv6Address}" Foreground="#E6EDF3" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <TextBlock Text="Subnet: " Foreground="#8B949E" FontSize="12"/>
                                                <TextBlock Text="{Binding IPv4SubnetMask}" Foreground="#E6EDF3" FontSize="12"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ────── SPEED TEST PAGE ────── -->
                <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVisConverter}, ConverterParameter=SpeedTest}">

                    <!-- Speed test controls -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="▶  Run Speed Test" Command="{Binding RunSpeedTestCommand}"
                                        IsEnabled="{Binding IsSpeedTestRunning, Converter={StaticResource InverseBooleanConverter}}"
                                        Background="#238636" Foreground="White" FontSize="14" FontWeight="SemiBold"
                                        Padding="20,10" Cursor="Hand" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2EA043"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="⏹  Cancel" Command="{Binding CancelSpeedTestCommand}"
                                        Background="#DA3633" Foreground="White" FontSize="13"
                                        Padding="14,10" Margin="12,0,0,0" Cursor="Hand" BorderThickness="0"
                                        Visibility="{Binding IsSpeedTestRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#E5534B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <!-- Progress -->
                            <ProgressBar Value="{Binding SpeedTestProgress}" Maximum="100" Height="6"
                                         Background="#21262D" Foreground="#00E676" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding SpeedTestStatus}" Foreground="#8B949E" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Results cards -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,4,0,0">
                        <Border Style="{StaticResource Card}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⬇ DOWNLOAD" FontSize="10" Foreground="#8B949E"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SpeedTestDownload}" FontSize="28" FontWeight="Bold"
                                           Foreground="#00E676" HorizontalAlignment="Center" Margin="0,8,0,0"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⬆ UPLOAD" FontSize="10" Foreground="#8B949E"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SpeedTestUpload}" FontSize="28" FontWeight="Bold"
                                           Foreground="#42A5F5" HorizontalAlignment="Center" Margin="0,8,0,0"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📶 LATENCY" FontSize="10" Foreground="#8B949E"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SpeedTestLatency}" FontSize="28" FontWeight="Bold"
                                           Foreground="#FF7043" HorizontalAlignment="Center" Margin="0,8,0,0"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <!-- ────── SETTINGS PAGE ────── -->
                <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageVisConverter}, ConverterParameter=Settings}">

                    <!-- General section -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="⚙  General" FontSize="15" FontWeight="SemiBold" Foreground="#E6EDF3" Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <CheckBox IsChecked="{Binding AlwaysOnTop}" VerticalAlignment="Center"/>
                                <TextBlock Text="Always on Top" Foreground="#C9D1D9" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <CheckBox IsChecked="{Binding LaunchOnStartup}" VerticalAlignment="Center"/>
                                <TextBlock Text="Launch on Startup" Foreground="#C9D1D9" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <CheckBox IsChecked="{Binding StartMinimized}" VerticalAlignment="Center"/>
                                <TextBlock Text="Start Minimized" Foreground="#C9D1D9" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <CheckBox IsChecked="{Binding ClickThroughEnabled}" VerticalAlignment="Center"/>
                                <TextBlock Text="Click-Through Overlay" Foreground="#C9D1D9" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Monitoring section -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="📡  Monitoring" FontSize="15" FontWeight="SemiBold" Foreground="#E6EDF3" Margin="0,0,0,12"/>

                            <StackPanel Margin="0,6">
                                <TextBlock Text="Network Adapter" Foreground="#8B949E" FontSize="12" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding AvailableAdapters}" SelectedItem="{Binding SelectedAdapterName}"
                                          Width="250" HorizontalAlignment="Left" FontSize="13"/>
                            </StackPanel>

                            <StackPanel Margin="0,10">
                                <TextBlock Foreground="#8B949E" FontSize="12" Margin="0,0,0,4">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Update Interval: {0} ms">
                                            <Binding Path="UpdateIntervalMs"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Slider Minimum="250" Maximum="5000" TickFrequency="250" IsSnapToTickEnabled="True"
                                        Value="{Binding UpdateIntervalMs}" Width="300" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <StackPanel Margin="0,10">
                                <TextBlock Foreground="#8B949E" FontSize="12" Margin="0,0,0,4">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Overlay Opacity: {0:P0}">
                                            <Binding Path="BackgroundOpacity"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Slider Minimum="0.3" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        Value="{Binding BackgroundOpacity}" Width="300" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Alerts section -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="🔔  Alerts" FontSize="15" FontWeight="SemiBold" Foreground="#E6EDF3" Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <CheckBox IsChecked="{Binding AlertOnDisconnect}" VerticalAlignment="Center"/>
                                <TextBlock Text="Alert on Disconnect" Foreground="#C9D1D9" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Margin="0,6">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding AlertOnSpeedDrop}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Alert on Speed Drop below" Foreground="#C9D1D9" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding SpeedDropThresholdMbps, StringFormat=F1}" Width="60" Margin="8,0,0,0"
                                             FontSize="13" Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                                             Padding="4,2" VerticalAlignment="Center"/>
                                    <TextBlock Text="Mbps" Foreground="#8B949E" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,6">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding AlertOnDataCap}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Alert when daily usage exceeds" Foreground="#C9D1D9" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding DailyDataCapGB, StringFormat=F1}" Width="60" Margin="8,0,0,0"
                                             FontSize="13" Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                                             Padding="4,2" VerticalAlignment="Center"/>
                                    <TextBlock Text="GB" Foreground="#8B949E" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Save / Reset buttons -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾  Save Settings" Command="{Binding SaveSettingsCommand}"
                                    Background="#238636" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                    Padding="16,8" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2EA043"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="↩  Reset Defaults" Command="{Binding ResetSettingsCommand}"
                                    Background="#30363D" Foreground="#C9D1D9" FontSize="13"
                                    Padding="16,8" Margin="12,0,0,0" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#484F58"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Text="{Binding SettingsStatus}" Foreground="#00E676" FontSize="13"
                                       VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
